# Next.js reads env files from the web/ directory when you run `npm run dev`
# here. Copy this to `web/.env.local` for local frontend development.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SIGNAL_EYE_API_URL=http://localhost:8000

# Optional: required only if you want Supabase auth enabled locally.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here

# Optional: required for Supabase-backed data reads or Stripe webhooks on the
# frontend server runtime.
SIGNAL_EYE_SUPABASE_SERVICE_ROLE_KEY=

# Optional: local billing and admin flows.
SIGNAL_EYE_FRONTEND_URL=http://localhost:3000
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=

# Optional opt-ins. These features are OFF by default when the vars are unset.
# Uncomment only for local testing or a self-hosted runtime.
# NEXT_PUBLIC_SIGNAL_EYE_ENABLE_DASHBOARD_POLLING=true
# NEXT_PUBLIC_SIGNAL_EYE_ENABLE_BREAKING_FEED_POLLING=true
# SIGNAL_EYE_ENABLE_SERVER_REFRESH_LOOP=true
